            <CheatEntry>
              <ID>1987731696</ID>
              <Description>"[ Noclip NR"</Description>
              <Options moHideChildren="1"/>
              <LastState Value="" RealAddress="00000000"/>
              <GroupHeader>1</GroupHeader>
              <CheatEntries>
                <CheatEntry>
                  <ID>1987731694</ID>
                  <Description>"Symbol Lookup Fix"</Description>
                  <LastState/>
                  <Color>0000FF</Color>
                  <VariableType>Auto Assembler Script</VariableType>
                  <AssemblerScript>{
    TGA
}
{$lua}
if syntaxcheck then return end

[ENABLE]
local sl = getMainSymbolList()
local mExec = {}
local mExecCnt = 0

for i, m in ipairs(enumMemoryRegions()) do
    if (m.Protect &amp; 0x20) == 0x20 then -- PAGE_EXECUTE_READ
        mExec[mExecCnt] = m
        mExecCnt = mExecCnt + 1
    end
end

-- Efficiently check if a page of memory is executable using binary search
-- on the list of all executable pages
function isExecutableMem(addr)
    addr = addr &amp; ~0x3FF -- Align to page size
    local low = 0
    local high = mExecCnt

    while low+1 &lt; high do
        local mid = (low + high) &gt;&gt; 1
        if mExec[mid].BaseAddress &lt; addr then low = mid
        elseif mExec[mid].BaseAddress &gt; addr then high = mid
        else low = mid; break; end
    end
    return addr &lt; mExec[low].BaseAddress + mExec[low].RegionSize
end

function getSymbolUnderscoreFix(symbolStr)
    local symbol = sl.getSymbolFromString(symbolStr)
    if (symbol == nil and string.sub(symbolStr, 1, 1) == "_") then
        symbol = sl.getSymbolFromString(string.sub(symbolStr, 2, string.len(symbolStr)))
    elseif (symbol == nil) then
        symbol = sl.getSymbolFromString("_" .. symbolStr)
    end
    return symbol
end

-- Override CE symbol lookup behavior to allow usage of the mingw
-- headers already installed with it, and fix a weird symbol lookup bug
-- where CE will not follow imports for some functions (ex: InitializeCriticalSection)
function onSymbolLookup(symbolStr)
    local symbol = getSymbolUnderscoreFix(symbolStr)
    if (symbol == nil) then
       return nil
    end

    -- Fix CE symbol lookup bug
    while not isExecutableMem(symbol.address) do
        local name = readString(symbol.address, 256)
        symbol = sl.getSymbolFromString(name)
        if symbol == nil then return nil end
    end
    return symbol.address
end

if (SymbolLookupCallbackId ~= nil) then
    unregisterSymbolLookupCallback(SymbolLookupCallbackId)
end
SymbolLookupCallbackId = registerSymbolLookupCallback(onSymbolLookup, slNotModule)


[DISABLE]
if (SymbolLookupCallbackId ~= nil) then
    unregisterSymbolLookupCallback(SymbolLookupCallbackId)
end
</AssemblerScript>
                </CheatEntry>
                <CheatEntry>
                  <ID>2000032499</ID>
                  <Description>"[ Noclip NR 2"</Description>
                  <Options moHideChildren="1"/>
                  <LastState/>
                  <Color>FF8080</Color>
                  <VariableType>Auto Assembler Script</VariableType>
                  <AssemblerScript>{
    Author: dasaav
    Taken from: Elden-Ring-CT-TGA
          https://github.com/The-Grand-Archives/Elden-Ring-CT-TGA

    Modified: Volkov_ilya37
    Added | Changed:
          Movement via GetAsyncKeyState
          Zero inAirTimer
          Custom speed multiplier
          Up &amp; Down hotkeys: 'Space' &amp; 'X'
          Doesn't need windows.h module anymore
          Fixed issue that blocked enemy movement
}

[ENABLE]
{$c}
#include &lt;stdbool.h&gt;
#include &lt;stdint.h&gt;
/*
#define WIN32_LEAN_AND_MEAN
#include &lt;windows.h&gt;

https://learn.microsoft.com/en-us/windows/win32/api/winuser/nf-winuser-getasynckeystate
virtual key codes:
https://learn.microsoft.com/en-us/windows/win32/inputdev/virtual-key-codes
*/
extern void* FieldArea;
extern void* CSFlipper;
extern void* WorldChrMan;
extern int16_t GetAsyncKeyState(int);

float speedMultiplier = 1.0f;

typedef struct {
    float x;
    float y;
} MoveInputXY;

typedef struct { float x, y, z, w; } Vector4;
typedef struct { Vector4 r0, r1, r2, r3; } Matrix44;

Vector4 mv_product_ignore_w(Matrix44* m, Vector4* v) {
    Vector4 result;
    result.x = m-&gt;r0.x * v-&gt;x + m-&gt;r1.x * v-&gt;y + m-&gt;r2.x * v-&gt;z;
    result.y = m-&gt;r0.y * v-&gt;x + m-&gt;r1.y * v-&gt;y + m-&gt;r2.y * v-&gt;z;
    result.z = m-&gt;r0.z * v-&gt;x + m-&gt;r1.z * v-&gt;y + m-&gt;r2.z * v-&gt;z;
    result.w = 0.0f;
    return result;
}

Matrix44* get_view_matrix() {
    if (!FieldArea) return NULL;
    void* chr_cam = *(void**)((uintptr_t)FieldArea + 0x68);
    if (!chr_cam) return NULL;
    return (Matrix44*)((uintptr_t)chr_cam + 0x10);
}

float get_delta_time() {
    if (!CSFlipper) return 0.016666f;
    return *(float*)((uintptr_t)CSFlipper + 0x270);
}

MoveInputXY get_keyboard_movement() {
    MoveInputXY input = {0.0f, 0.0f};

    if (GetAsyncKeyState('W') &lt; 0) input.y += 1.0f;
    if (GetAsyncKeyState('S') &lt; 0) input.y -= 1.0f;
    if (GetAsyncKeyState('D') &lt; 0) input.x += 1.0f;
    if (GetAsyncKeyState('A') &lt; 0) input.x -= 1.0f;

    return input;
}

float get_up_down_input() {
    float ud = 0.0f;
    if (GetAsyncKeyState(0x20) &lt; 0) ud += 1.0f;
    if (GetAsyncKeyState('X') &lt; 0) ud -= 1.0f;
    return ud;
}
{$asm}
aobscanmodule(noclipAOB,nightreign.exe,F3 0F 11 73 70 F3 0F 11 7B 74)
registerSymbol(noclipAOB)
alloc(physics_update_hook, 2048, noclipAOB)
alloc(flyFlag,1)
registerSymbol(flyFlag)
label(skipCode)
label(isMainChr)

physics_update_hook:
  cmp byte ptr [flyFlag],01
  jne skipCode
  call isMainChr
  test al,al
  je skipCode
{$ccode physics_module=rbx}
Matrix44* view_matrix = get_view_matrix();
if (view_matrix) {
   MoveInputXY input = get_keyboard_movement();
   // Get up/down movement.
   float ud_input = get_up_down_input();

   // Map movement to world coordinates.
   Vector4 input_vec = { input.x, 0.0f, input.y, 0.0f };

   // Scale movement to approx. 10 m/s.
   float scale = 10 * speedMultiplier * get_delta_time();
   input_vec.x *= scale;
   input_vec.z *= scale;
   ud_input *= 0.7f * scale;

   // Transform movement to camera space.
   Vector4 product = mv_product_ignore_w(view_matrix, &amp;input_vec);

   // Offset player position.
   Vector4* player_pos = (Vector4*)((uintptr_t)physics_module + 0x70);
   player_pos-&gt;x += product.x;
   player_pos-&gt;y += product.y + ud_input;
   player_pos-&gt;z += product.z;

   // Disable gravity
   *(char*)((uintptr_t)physics_module + 0x1e6) = 1;

   // Zero in air Timer
   float* ptr_inAirTimer = (float*)(*(char**)(*(char**)(*(char**)((char*)WorldChrMan+0x174e8)+0x1B8)+0x70)+0x18);
   *ptr_inAirTimer = 0.0f;
}


{$asm}
  jmp noclipAOB+10
skipCode:
  movss [rbx+70],xmm6
  movss [rbx+74],xmm7
  movss [rbx+78],xmm8
  jmp noclipAOB+10

isMainChr:
  push rcx
  xor rax,rax
  mov rcx,WorldChrMan
  mov rcx,[rcx]
  mov rcx,[rcx+XA]
  mov rcx,[rcx+1B8]
  mov rcx,[rcx+68]
  cmp rbx,rcx
  setz al
  pop rcx
  ret


flyFlag:
 db 01

noclipAOB:
  jmp physics_update_hook

[DISABLE]
[[WorldChrMan]+174E8]+1e6:
  db 00

noclipAOB:
  movss [rbx+70],xmm6

unregisterSymbol(noclipAOB)
dealloc(physics_update_hook)
dealloc(flyFlag)
unregisterSymbol(flyFlag)
</AssemblerScript>
