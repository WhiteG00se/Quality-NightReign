                <CheatEntry>
                  <ID>1987697769</ID>
                  <Description>"Effect Logger"</Description>
                  <LastState/>
                  <Color>0000FF</Color>
                  <VariableType>Auto Assembler Script</VariableType>
                  <AssemblerScript>[ENABLE]

aobscanmodule(EffectIconAccessor,nightreign.exe,F3 0F 59 71 08 0F 57 C0 0F 2F C6 F3 0F 11 73 4C)
alloc(EffectHook,$1000,EffectIconAccessor)
label(EffectLog)
label(loopstart)
label(exit)
registerSymbol(EffectLog)

EffectHook:
mulss xmm6,[rcx+08]
test r13d,r13d
je exit
lea r8,[EffectLog]
lea r9,[EffectHook+FF8]
loopstart:
cmp [r8],r13d
je exit
cmp [r8],0
jne loopnext
mov [r8],r13d
ret
loopnext:
add r8,8
cmp r8,r9
jbe loopstart
exit:
ret
align 8
EffectLog:

EffectIconAccessor:
call EffectHook

{$lua}


EffectLogForm.OnClose=function(sender)
    getAddressList().getMemoryRecordByID(8888).Active=false
end
EffectLogForm.OnResize=function(sender)
    sender.EditVFXID.Top=sender.ClientHeight-sender.EditVFXID.Height
    sender.EditVFXID.Width=sender.ClientWidth-sender.EditVFXID.Left
    sender.LabelVFXID.Top=sender.EditVFXID.Top+(sender.EditVFXID.Height-sender.LabelVFXID.Height)/4
    sender.EditEffectID.Top=sender.EditVFXID.Top-sender.EditVFXID.Height-2
    sender.EditEffectID.Width=sender.ClientWidth-sender.EditEffectID.Left
    sender.LabelEffectID.Top=sender.EditEffectID.Top+(sender.EditEffectID.Height-sender.LabelEffectID.Height)/4
    sender.EffectList.setSize(sender.ClientWidth,sender.EditEffectID.Top)
end
EffectLogForm.OnResize(EffectLogForm)

EffectLogForm.EffectList.OnSelectItem=function(sender)
    local item=sender.Selected
    if item then
        EffectLogForm.EditEffectID.Text=item.getCaption()
        if item.SubItems.Count&gt;=2 then
            EffectLogForm.EditVFXID.Text=item.SubItems[1]
        end
    end
end

EffectLogForm.EffectList.OnDblClick=function(sender)
    local item=sender.Selected
    if item then
        writeInteger(ParamID+4*15,tonumber(item.getCaption()))
    end
end

function UpdateEffectList()

    local EffectLog=getAddressSafe("EffectLog")
    local items=EffectLogForm.EffectList.getItems()
    for i=0,4096/8-1 do
        local Effect_id=readInteger(EffectLog+i*8)
        if Effect_id==0 then
           break
        end
        local Effect_addr=ParamCacheV4[15][Effect_id]
        if Effect_id then
            local item
            if i&lt;items.Count then
               item=items[i]
            else
               item=items.add()
            end
            local s=tostring(Effect_id)
            if s~=item.getCaption() then
               item.setCaption(s)
            end
            s=tostring(readFloat(Effect_addr+8))
            if item.SubItems.Count&lt;1 then
                item.SubItems.add(s)
            elseif item.SubItems[0]~=s then
                item.SubItems[0]=s
            end
            s=tostring(readInteger(Effect_addr+0x170,true))
            if item.SubItems.Count&lt;2 then
                item.SubItems.add(s)
            elseif item.SubItems[1]~=s then
                item.SubItems[1]=s
            end
        end
    end
end

EffectLogForm.EffectList.OnKeyDown=function(sender,key)
    if key==0x2E then
        local EffectLog=getAddressSafe("EffectLog")
        for i=0,4096/8-1 do
            writeQword(EffectLog+i*8,0)
        end
        sender.getItems().clear()
    elseif key==67 and isKeyPressed(17) then
       CopyListView(sender)
    end
end

EffectLogForm.OnResize(EffectLogForm)
EffectLogTimer=createTimer(nil,true)
EffectLogTimer.Interval=256
EffectLogTimer.OnTimer=function(timer)
    if not pcall(UpdateEffectList) then
        getAddressList().getMemoryRecordByID(8888).Active=false
    end
end

EffectLogForm.show()
[DISABLE]
{$lua}
if EffectLogTimer then
   EffectLogTimer.destroy()
   EffectLogTimer=nil
end
EffectLogForm.hide()
EffectLogForm.EditEffectID.Text=""
EffectLogForm.EditVFXID.Text=""
EffectLogForm.EffectList.getItems().clear()
{$asm}

EffectIconAccessor:
  db F3 0F 59 71 08

unregistersymbol(EffectIconAccessor)
dealloc(EffectHook)
