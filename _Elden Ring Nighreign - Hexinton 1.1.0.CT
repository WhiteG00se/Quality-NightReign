                  <Description>"Inf Revivify"</Description>
                  <Options moHideChildren="1"/>
                  <LastState/>
                  <VariableType>Auto Assembler Script</VariableType>
                  <AssemblerScript>{$lua}
[ENABLE]
local function Inf()
    if  playYes() then
    local hp = GetHP()
    local anim = GetAnim()
    if hp &lt;= 0 and ( anim == 4000 or anim == 4100 or anim == 202040 or (anim &gt;= 17000 and anim &lt;= 19000) or (anim &gt;= 60000 and anim &lt;= 99000) ) then
        SetHp(max)
        SetFp(max)
        SetStamina(max)
        PlayAnimByNumericalId(0)
    end
    end
end

InfHPTimer = Timer:new(100,Inf)

[DISABLE]
if InfTimer then
InfHPTimer:kil1()
InfHpTimer=nil
end
