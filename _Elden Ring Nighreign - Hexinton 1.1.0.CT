function setModel(model)
  if not model then
     print("Model Id is not provided")
     return
  end
  writeInteger("[[GameDataMan]+08]+350",model)
end

function randomModel()
  local idx = math.random(1,#allModels)
  writeInteger("[[GameDataMan]+08]+350",allModels[idx])
end

