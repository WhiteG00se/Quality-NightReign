                <CheatEntry>
                  <ID>2000032324</ID>
                  <Description>"[ Relic injected into backpack"</Description>
                  <Options moHideChildren="1" moActivateChildrenAsWell="1" moDeactivateChildrenAsWell="1"/>
                  <LastState/>
                  <Color>0080FF</Color>
                  <VariableType>Auto Assembler Script</VariableType>
                  <AssemblerScript>[ENABLE]
{
  MADE BY 4shi_M/
  Thanks to ff_enjoy(wshr黎) for the help/
}
aobscanmodule(antiqueAOB1,nightreign.exe,45 0F B6 E1 4D 8B F0 48 8B DA 48 8B F1 33 FF)
aobscanmodule(antiqueAOB2,nightreign.exe,45 0F B6 F1 45 8B F8 4C 8B E2 48 8B D9 33 F6)
aobscanmodule(antiqueAOB3,nightreign.exe,48 33 C4 48 89 45 ?? 8B F2 48 8B F9 48 89 4C 24 ?? 33 DB)
registersymbol(antiqueAOB1)
registersymbol(antiqueAOB2)
registersymbol(antiqueAOB3)
alloc(getAntique,2048,nightreign.exe)
registersymbol(getAntique)
alloc(antique,280)
registersymbol(antique)

getAntique:
 sub rsp,0x228
 mov rcx,[CSGaitem]
 mov rax,[GameDataMan]
 mov r14,[rax+08]
 xor r9d,r9d
 lea r8,[antique+20]
 lea rdx,[antique]
 call antiqueAOB1-1E
 nop
 mov byte ptr [rsp+28],00
 mov byte ptr [rsp+20],00
 xor r9d,r9d
 lea r8d,[r9+01]
 lea rdx,[antique]
 lea rcx,[r14+000001D8]
 call antiqueAOB2-24
 mov edx,eax
 lea rcx,[rsp+00000090]
 call antiqueAOB3-21
 nop
 add rsp,0x228
 ret
antique:
dd 0
antique+4:
dd 0
{antique+8:
dd 069AE949
antique+C:
dd #128
antique+10:
dd 7C940000
antique+14:
dd #391
antique+18:
dd DE86CC9A
antique+1C:
dd #32762}
antique+20:
dd 80000000
antique+24:
dd FFFFFFFF
antique+28:
dd FFFFFFFF
antique+2C:
dd FFFFFFFF
antique+30:
dd FFFFFFFF
antique+34:
dd FFFFFFFF
antique+38:
dd FFFFFFFF
antique+3C:
dd 0
antique+40:
dd 0
antique+44:
dd 0
antique+48:
dd FFFFFFFF
antique+4C:
dd FFFFFFFF
antique+50:
dd FFFFFFFF
antique+54:
dd FFFFFFFF
antique+58:
dd FFFFFFFF
{$lua}
function injectAntique(antiqueid,attributetable)
  local trueid = antiqueid+2147483648
  local addr = getAddress("antique")
  writeInteger(addr+32,trueid)

  writeInteger(addr+0x28,attributetable[1])
  writeInteger(addr+0x2C,attributetable[2])
  writeInteger(addr+0x30,attributetable[3])
  writeInteger(addr+0x50,attributetable[4])
  writeInteger(addr+0x54,attributetable[5])
  writeInteger(addr+0x58,attributetable[6])

  createRemoteThread("getAntique")
end
[DISABLE]
{$asm}
dealloc(getAntique)
unregistersymbol(getAntique)
dealloc(antique)
unregistersymbol(antique)
unregistersymbol(antiqueAOB1)
unregistersymbol(antiqueAOB2)
unregistersymbol(antiqueAOB3)
</AssemblerScript>
