                                  <AssemblerScript>{
  Author: Volkov_ilya37
}

[ENABLE]
{$lua}
if syntaxcheck then return end

local stones = {
0x40000578, --:Fire Grease
0x40000582, --:Lightning Grease
0x4000058C, --:Magic Grease
0x40000596, --:Holy Grease
0x400005A0, --:Blood Grease
0x400005AA, --:Soporific Grease
0x400005B4, --:Poison Grease
0x400005BE, --:Freezing Grease
0x400005C8, --:Dragonwound Grease
0x400005D2 -- :Rot Grease
}
local upgrade = readByte("Menu_Drop+4")
local weapon_art = readInteger("Menu_Drop+1C")
local wepEffect = readInteger("Menu_Drop+8")
local effectTier = readByte("Menu_Drop+C")
local magic_1 = readInteger("Menu_Drop+10")
local magic_2 = readInteger("Menu_Drop+14")
local quantity = 2

for _,i in ipairs(stones) do
    dropItem(i, upgrade, weapon_art, wepEffect, effectTier, magic_1, magic_2, quantity)
    sleep(5)
end

disableMemrec(memrec)

[DISABLE]
{$lua}
if syntaxcheck then return end

