                        <CheatEntry>
                          <ID>2000032461</ID>
                          <Description>"Quantity"</Description>
                          <ShowAsSigned>0</ShowAsSigned>
                          <VariableType>Byte</VariableType>
                          <Address>Menu_item+18</Address>
                        </CheatEntry>
                        <CheatEntry>
                          <ID>2000032462</ID>
                          <Description>"← Inject Item"</Description>
                          <LastState/>
                          <Color>000080</Color>
                          <VariableType>Auto Assembler Script</VariableType>
                          <AssemblerScript>[ENABLE]
{$lua}
if syntaxcheck then return end

local id = readInteger("Menu_item")
local upgrade = readByte("Menu_item+4")
local weapon_art = readInteger("Menu_item+1C")
local effectTier = readByte("Menu_item+C")
local magic_1 = readInteger("Menu_item+10")
local magic_2 = readInteger("Menu_item+14")
local quantity = readByte("Menu_item+18")
local itemIdx = readInteger("Menu_item+28")

local wepEffectTable = {
readInteger("Menu_item+8"),
readInteger("Menu_item+20"),
readInteger("Menu_item+24")
}

injectItem(id, upgrade, weapon_art, wepEffectTable, effectTier, magic_1, magic_2, quantity, itemIdx)
disableMemrec(memrec)
[DISABLE]
</AssemblerScript>
