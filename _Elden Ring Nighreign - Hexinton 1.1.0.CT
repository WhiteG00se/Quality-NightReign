                  <VariableType>Auto Assembler Script</VariableType>
                  <AssemblerScript>{
    Author: Volkov_ilya37
    Discord invite link:
         https://discord.gg/mrj2mH9AN6
}

[ENABLE]
aobscanmodule(TLSSlotFetcherItemInject,nightreign.exe,8D 41 0F 03 C2 83 E0 F0 41 89 00 8B 0D)
aobscanmodule(ItemInjectCallAOB,nightreign.exe,40 55 53 56 57 41 54 41 55 41 56 41 57 48 8d 6c 24 f9 48 81 ec d8 00 00 00)
registersymbol(TLSSlotFetcherItemInject)
registersymbol(ItemInjectCallAOB)
alloc(ItemInjector,$256,nightreign.exe)
registerSymbol(ItemInjector)
alloc(ItemBuf,280)
registersymbol(ItemBuf)
alloc(itemSlot,4)
registerSymbol(itemSlot)

itemSlot:
 dd 1

ItemInjector:
 sub rsp,228
 mov rcx, TLSSlotFetcherItemInject+D
 mov eax, [rcx]
 cdqe
 mov ecx, [rcx+rax+4]
 mov rdx, nightreign.exe+3BAAF78
 call TlsSetValue
 mov rcx,MapItemMan
 mov rcx,[rcx]
 mov rax,ItemBuf
 lea rdx,[rax]
 mov r15d,[itemSlot]
 mov [rsp+30],r15d
 xor r15d,r15d
 mov byte ptr [rsp+28],00
 mov byte ptr [rsp+20],00
 lea r9,[rax+6C]
 lea r8,[rax+A4]
 call ItemInjectCallAOB
 add rsp,228
 ret

ItemBuf:
 dd 1

ItemBuf+4:
 dd 0

ItemBuf+8:
 dd FFFFFFFF

ItemBuf+C:
 dd FFFFFFFF

ItemBuf+10:
 dd FFFFFFFF

ItemBuf+14:
 dd FFFFFFFF

ItemBuf+18:
 dd FFFFFFFF

ItemBuf+1C:
 dd FFFFFFFF

ItemBuf+20:
 dd FFFFFFFF

ItemBuf+24:
 dd 0

ItemBuf+28:
 dd 0

ItemBuf+2C:
 dd 0

ItemBuf+30:
 dd FFFFFFFF

ItemBuf+34:
 dd FFFFFFFF

ItemBuf+38:
 dd FFFFFFFF

ItemBuf+3C:
 dd FFFFFFFF

ItemBuf+40:
 dd FFFFFFFF

ItemBuf+44:
 dd 0

ItemBuf+48:
 dd FFFF0001
{$lua}
if syntaxcheck then return end

local Aboba = AOBScanModuleUnique("nightreign.exe","45 33 C0 33 D2 E8 ?? ?? ?? ?? 45 8B DF 48 85 C0 0F 84 ?? ?? ?? ?? 48 8B 80 80 00 00 00 48 8B 90 80 00 00 00") - 0x7A

local function getItemType(id)
	local types = {
		weapon = {0x00000000, "Weapon"},
		protector = {0x10000000, "Armor"},
		accessory = {0x20000000, "Talismans"},
		goods = {0x40000000, "Goods"},
		gem = {0x80000000, "Gem"},
		invalid = {0xF0000000, "Invalid"}
	}

	local v = 0x0FFFFFFF
	if id &gt;= types.weapon[1] and id &lt;= types.weapon[1] + v then
		return types.weapon
	elseif id &gt;= types.protector[1] and id &lt;= types.protector[1] + v then
		return types.protector
	elseif id &gt;= types.accessory[1] and id &lt;= types.accessory[1] + v then
		return types.accessory
	elseif id &gt;= types.goods[1] and id &lt;= types.goods[1] + v then
		return types.goods
	elseif id &gt;= types.gem[1] and id &lt;= types.gem[1] + v then
		return types.gem
	else
		return types.invalid
	end
end

local capLevels = {
    [0] = {
        8883100,
        8370000, 8610600,
        8881200, 8650000, 8460200,
        8884000, 8885000, 8883000, 8884100,
        8884200, 8885100, 8885200, 8884300, 8520001,
        8330500, 8330700, 8460500, 8530000, 8530100, 8610500,
        8610000, 8610100, 8620010, 8610300, 8610400, 8350400, 8360000,
        8330900, 8610700, 8620100, 8652000, 8320400, 8450000, 8450100, 8460100,
        8410100, 8420100, 8420200, 8430000, 8440200, 8600300, 8620000, 8640000, 8640100,
        8460300, 8460400, 8460500, 8500000, 8530200, 8880200, 8880300, 8880400, 8881000, 8881100,
        8650100, 8652100, 8660200, 8880000, 8880100, 8882100, 8882200, 8882300, 8882300, 8882400, 8882500,
        8881300, 8881400, 8881500, 8881600, 8882000
    },
    [1] = {
        8000000, 8010000, 8010100, 8020000,
        8100000, 8100100, 8100200, 8100300, 8100400, 8330400,
        8200000, 8200100, 8200200, 8200300, 8200400, 8200500,
        8020100, 8020200, 8120000, 8230000
    },
    [2] = {
        8300000, 8350000, 8320300, 8320100, 8420000, 8670000, 8110000, 8110300, 8110600, 8111000, 8310000,
        8600100, 8600200, 8130000, 8330600, 8330000, 8330200, 8320000, 8660000, 8110900, 8110800,
        8330100, 8330300, 8340000, 8340100, 8510000, 8140000, 8110200, 8110700,
        8660100, 8670100, 8210000, 8210100, 8210200, 8210300, 8110500,
        8210400, 8210500, 8210600, 8111000, 8110100, 8110400
    }
}

local effectCapMap = {}
for cap, ids in pairs(capLevels) do
    for _, id in ipairs(ids) do
        effectCapMap[id] = cap
    end
end


function injectItem(itemId, wepUpgrade, weaponArt, wepEffectTable, effectTier, magicSkill_1, magicSkill_2, quantity, itemIdx)
  local function switchCase(tableCases, case, ...)
    if not tableCases[case] or nil then
       print("nil")
       return "Invalid"
    else
       return tableCases[case](...)
    end
  end

  local function getEffectCap(effectId)
     if effectId == -1 or effectId == 0 then
        return 0
     else
        return effectCapMap[effectId]
     end
  end

  local function getWeaponAddr(id)
     local buf = allocateMemory(32)
     executeCodeEx(0,-1,Aboba,buf,id)
     local result = readPointer(buf+8)
     deAlloc(buf)
     return result
  end

  local function isCastingWep(param)
     local isCasting = readInteger(param+4)
     if isCasting == 3300 or isCasting == 3400 then
        return true
     end
     return false
  end

  local function checkTier(id,wepUpgr)
     if wepUpgr &gt; 3 then wepUpgr = 3 end
     local weaponAddr = getWeaponAddr(id)
     local baseUpgrade = readInteger(weaponAddr + 0x5C)
     if baseUpgrade == 0xFFFFFFFF then
        return 0
     end
     baseUpgrade = math.floor(baseUpgrade / 100)
     if baseUpgrade == 2 and wepUpgr &gt; 1 then
        return 1
     elseif baseUpgrade == 1 and wepUpgr == 3 then
        return 2
     else
        return wepUpgr
     end
  end

  local function WeaponItemFunc()
     -- # valid magic Skill for staffs and seals
     if (magicSkill_1 &gt;= 4000 and magicSkill_1 &lt;= 8001) or (magicSkill_2 &gt;= 4000 and magicSkill_2 &lt;= 8001) then
        local wepAddr = getWeaponAddr(itemId)
        if isCastingWep(wepAddr) then
           weaponArt = -1
        else
           magicSkill_1 = -1
           magicSkill_1 = -1
        end
     end

     -- # valid effectId and upgradeTier
     if type(wepEffectTable) ~= "table" then
        print("Weapon Effects should be passed as table")
        return
     end
     for k, value in ipairs(wepEffectTable) do
         local cap = getEffectCap(value)
         if not cap then
            effectTier = 0
         elseif effectTier ~= 0 and effectTier &gt; cap then
            effectTier = cap
         end
         wepEffectTable[k] = value + effectTier
     end

     -- # valid Item upgrade
     local validUpgrade = checkTier(itemId,wepUpgrade)
     itemId = itemId + validUpgrade

     quantity = 1
  end

  local function InvalidItemFunc()
     printf("Invalid Item ID: %d (0x%X)",itemId,itemId)
     itemId = -1
  end

  local function defaultSettings()
     wepEffectTable[1] = -1
     wepEffectTable[2] = -1
     wepEffectTable[3] = -1
     weaponArt = -1
     magicSkill_1 = -1
     magicSkill_2 = -1
     effectTier = 0
     wepUpgrade = 0
  end

  local function TalismanItemFunc()
     defaultSettings()
     quantity = 1
  end

  local function GoodsItemFunc()
     if quantity == 0 then
        quantity = 1
     elseif quantity &gt; 8 then
        quantity = 8
     end
     defaultSettings()
  end

  local addr = getAddress("ItemBuf")
  if not itemId or itemId == 0 then print("No Item Id provided") return end
  local itemType = getItemType(itemId)


local itemTypeManager = {
  ["Weapon"] = WeaponItemFunc,
  ["Talismans"] = TalismanItemFunc,
  ["Goods"] = GoodsItemFunc,
  ["Armor"] = InvalidItemFunc,
  ["Gem"] = InvalidItemFunc,
  ["Invalid"] = InvalidItemFunc
}

switchCase(itemTypeManager,itemType[2])

  if itemId == -1 then return end

-- # Item Slot Management
  if itemIdx == 10000 then  -- auto
     if itemType[2] == "Weapon" then
        for i = 0,5 do
            local Base = string.format("[[GameDataMan]+8]+30C+%X", i * 4)
            local weaponId = readInteger(Base)
                  if weaponId == 110000 then
                     itemIdx = i
                     break
                  end
                  if i == 5 and weaponId ~= 110000 then
                     itemIdx = 1
                  end
        end
     elseif itemType[2] == "Talismans" then
            for i = 0,1 do
                local Base = string.format("[[GameDataMan]+8]+360+%X", i * 4)
                local talismanId = readInteger(Base)
                if talismanId == 0xFFFFFFFF then
                   itemIdx = i + 21
                   break
                elseif talismanId ~= 0xFFFFFFFF and i == 1 then
                   itemIdx = 21
                end
            end
     elseif itemType[2] == "Goods" then
            itemIdx = 0xFFFFFFFF
     end
  end

  -- final write
  writeInteger(addr + 0x8,itemId)
  writeInteger(addr + 0xC,weaponArt)
  writeInteger(addr + 0x10,wepEffectTable[1])
  writeInteger(addr + 0x14,wepEffectTable[2])
  writeInteger(addr + 0x18,wepEffectTable[3])
  writeInteger(addr + 0x1C,magicSkill_1)
  writeInteger(addr + 0x20,magicSkill_2)
  writeByte(addr + 0x48,quantity)
  writeInteger("itemSlot",itemIdx)
  createRemoteThread("ItemInjector")
end

[DISABLE]
{$lua}
if syntaxcheck then return end
injectItem = nil

{$asm}
dealloc(ItemInjector)
unregisterSymbol(ItemInjector)
dealloc(ItemBuf)
unregisterSymbol(ItemBuf)
unregistersymbol(TLSSlotFetcherItemInject)
dealloc(itemSlot)
unregisterSymbol(itemSlot)
unregisterSymbol(ItemInjectCallAOB)
